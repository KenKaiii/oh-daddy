{
	"name": "oh-daddy",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "concurrently -n next,inngest -c blue,magenta \"next dev\" \"npx inngest-cli@latest dev -u http://localhost:3000/api/inngest\"",
		"dev:next": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:all": "vitest run && vitest run --config vitest.integration.config.ts",
		"test:smoke": "node scripts/inngest-smoke.mjs",
		"format": "biome format --write",
		"check": "biome check --write",
		"db:push": "psql \"$DATABASE_URL\" -f db/schema.sql",
		"db:encrypt-secrets": "node db/encrypt-existing-secrets.mjs"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"inngest": "^4.11.0",
		"next": "16.2.9",
		"ogl": "^1.0.11",
		"postgres": "^3.4.9",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^26",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"concurrently": "^10.0.3",
		"inngest-cli": "^1.33.0",
		"tailwindcss": "^4",
		"typescript": "^6",
		"vitest": "^4.1.9"
	}
}
